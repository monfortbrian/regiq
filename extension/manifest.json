{
  "manifest_version": 3,
  "name": "RegIQ",
  "version": "1.0.0",
  "description": "Regulatory answers, grounded in official circulars/directives.",
  "host_permissions": ["https://flagcdn.com/*"],
  "permissions": [
    "sidePanel",
    "activeTab"
  ],
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "RegIQ",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}